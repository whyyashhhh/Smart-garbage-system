PORT=5000
NODE_ENV=development

# Local MongoDB example:
# MONGODB_URI=mongodb://127.0.0.1:27017/smart-garbage-reporting

# MongoDB Atlas example:
# MONGODB_URI=mongodb+srv://<username>:<urlencoded-password>@<cluster>.mongodb.net/smart-garbage-reporting?retryWrites=true&w=majority
MONGODB_URI=

JWT_SECRET=replace-with-a-strong-random-secret

# Public app URL used in notification links, e.g. https://your-app.vercel.app
APP_BASE_URL=

# Admin notification email address
ADMIN_EMAIL=

# Optional SMTP (required only if email notifications are enabled)
EMAIL_USER=
EMAIL_PASSWORD=